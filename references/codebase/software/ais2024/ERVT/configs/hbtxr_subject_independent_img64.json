{
  "device": "cuda:0",
  "mlflow_path": "./mlruns",
  "experiment_name": "ERVT_HBTXR",
  "data_dir": "./event_data_hbtxr_img64",
  "data_list_dir": "./event_data_hbtxr_img64/dataset",
  "run_name": "ERVT_subject_independent_img64",
  "architecture": "RVT",
  "expansion_ratio": 2,
  "mlp_gated": true,
  "gamma": 0.98,
  "mlp_bias": true,
  "drop_prob": 0.6,
  "tbptt": 15,
  "stages": [
    {
      "kernel_size": 7,
      "output_channels": 32,
      "stride": 2,
      "dim_head": 32
    },
    {
      "kernel_size": 3,
      "output_channels": 64,
      "stride": 2,
      "dim_head": 32
    }
  ],
  "lr": 0.001,
  "weight_decay": 0.00001,
  "scheduler": "HBTXRStepLR",
  "num_epochs": 70,
  "batch_size": 32,
  "num_workers": 8,
  "seed": 42,
  "spatial_factor": 1.0,
  "temporal_subsample_factor": 1.0,
  "val_interval": 1,
  "save_k_best": 2,
  "pixel_tolerances": [1, 3, 5, 10, 15],
  "sensor_width": 64,
  "sensor_height": 64,
  "train_stride": 15,
  "val_stride": 30,
  "train_length": 30,
  "val_length": 30,
  "in_channels": 3,
  "n_time_bins": 3,
  "voxel_grid_ch_normaization": true,
  "test_stride": 30,
  "test_length": 30,
  "loss": "weighted_rmse",
  "data_augmentation": {
    "prob_hflip": 0.5,
    "prob_noise": 0.5,
    "max_noise_factor": 2.2,
    "min_noise_factor": 0.05,
    "time_reversal": 0,
    "random_time_shift": 0
  }
}
